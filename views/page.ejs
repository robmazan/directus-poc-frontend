<%- include('partials/header', { title: title }) %>

<div class="page-wrapper">
  <header class="topbar">
    <span class="topbar-brand">Directus App</span>
    <nav class="topbar-nav">
      <a href="/" class="btn btn-secondary topbar-link">&larr; All Pages</a>
      <a href="/dashboard" class="btn btn-secondary topbar-link">Dashboard</a>
      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn btn-secondary">Sign Out</button>
      </form>
    </nav>
  </header>

  <main class="content">
    <article
      data-directus="collection:pages;item:<%= page.id %>;fields:title,slug,status,rows;mode:popover"
    >
      <h1>
        <%= page.title %>
      </h1>

      <div class="page-rows">
        <% page.rows.forEach(function(row) { %>
          <div
            class="page-row"
            data-directus="collection:rows;item:<%= row.id %>;fields:name,sort;mode:popover"
          >
            <% row.stacks.forEach(function(stack) { %>
              <div
                class="page-stack"
                data-directus="collection:stacks;item:<%= stack.id %>;fields:name,sort;mode:popover"
              >
                <% stack.bricks.forEach(function(brick) { %>
                  <% if (brick.collection === 'brick_texts') { %>
                    <brick-text
                      data-directus="collection:brick_texts;item:<%= brick.item.id %>;fields:content;mode:drawer"
                      content="<%- encodeURIComponent(brick.item.content || '') %>"
                    ></brick-text>
                  <% } else if (brick.collection === 'brick_images') { %>
                    <brick-image
                      data-directus="collection:brick_images;item:<%= brick.item.id %>;fields:image;mode:drawer"
                      src="<%= directusUrl %>/assets/<%= brick.item.image %>"
                      alt=""
                    ></brick-image>
                  <% } %>
                <% }); %>
              </div>
            <% }); %>
          </div>
        <% }); %>
      </div>
    </article>
  </main>
</div>

<script>window.__DIRECTUS_URL__ = '<%= directusUrl %>';</script>
<%- include('partials/footer') %>
